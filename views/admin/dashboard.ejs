<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — Al-Ahmed Agri</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Nunito', sans-serif; background: #f0f4f0; color: #222; }

    /* SIDEBAR */
    .admin-layout { display: flex; min-height: 100vh; }
    .sidebar {
      width: 240px; background: linear-gradient(180deg, #1a3a12 0%, #0d2008 100%);
      color: #fff; padding: 2rem 1.5rem; flex-shrink: 0;
      position: sticky; top: 0; height: 100vh; overflow-y: auto;
    }
    .sidebar-logo { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2.5rem; }
    .sidebar-logo .icon { font-size: 2rem; }
    .sidebar-logo .text h2 { font-size: 1rem; font-weight: 800; }
    .sidebar-logo .text p { font-size: 0.75rem; opacity: 0.7; }
    .sidebar-nav a {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.7rem 1rem; border-radius: 10px; color: rgba(255,255,255,0.7);
      text-decoration: none; font-weight: 500; font-size: 0.9rem;
      transition: all 0.2s; margin-bottom: 0.25rem;
    }
    .sidebar-nav a:hover, .sidebar-nav a.active { background: rgba(255,255,255,0.15); color: #fff; }
    .sidebar-nav .nav-section { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.5; margin: 1.25rem 0 0.5rem; padding: 0 1rem; }
    .sidebar-logout { margin-top: auto; padding-top: 2rem; }
    .sidebar-logout a { display: block; text-align: center; padding: 0.75rem; background: rgba(255,255,255,0.1); border-radius: 10px; color: #fff; text-decoration: none; font-size: 0.9rem; }
    .sidebar-logout a:hover { background: rgba(255,255,255,0.2); }

    /* MAIN */
    .admin-main { flex: 1; padding: 2rem; overflow-x: hidden; }
    .admin-topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
    .admin-topbar h1 { font-size: 1.75rem; font-weight: 800; color: #1a3a12; }
    .admin-topbar p { color: #888; font-size: 0.875rem; }
    .badge-admin { background: #d4af37; color: #fff; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; }

    /* STATS CARDS */
    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem; }
    .stat-card { background: #fff; border-radius: 14px; padding: 1.5rem; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
    .stat-card .num { font-size: 2.5rem; font-weight: 800; color: #1a3a12; }
    .stat-card .label { color: #888; font-size: 0.875rem; margin-top: 0.25rem; }
    .stat-card .icon { font-size: 1.5rem; margin-bottom: 0.5rem; }

    /* SECTIONS */
    .admin-section { background: #fff; border-radius: 14px; padding: 1.75rem; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 2rem; }
    .section-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem; }
    .section-head h2 { font-size: 1.25rem; font-weight: 800; color: #1a3a12; }

    /* FORMS */
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.35rem; }
    .form-group.full { grid-column: 1/-1; }
    label { font-size: 0.8rem; font-weight: 700; color: #555; text-transform: uppercase; letter-spacing: 0.05em; }
    input[type="text"], input[type="email"], textarea, select, input[type="file"] {
      border: 2px solid #e8e8e8; border-radius: 8px; padding: 0.65rem 0.9rem;
      font-family: inherit; font-size: 0.9rem; transition: border-color 0.2s; width: 100%;
    }
    input:focus, textarea:focus, select:focus { outline: none; border-color: #2d6a1a; }
    .checkbox-row { display: flex; align-items: center; gap: 0.5rem; }
    .checkbox-row input { width: auto; }

    /* BUTTONS */
    .btn-add { background: linear-gradient(135deg, #2d6a1a, #1a4010); color: #fff; border: none; padding: 0.65rem 1.25rem; border-radius: 8px; font-family: inherit; font-weight: 600; cursor: pointer; font-size: 0.875rem; transition: transform 0.2s; }
    .btn-add:hover { transform: translateY(-1px); }
    .btn-del { background: #fff0f0; color: #c0392b; border: 1px solid #fcc; padding: 0.4rem 0.8rem; border-radius: 6px; font-family: inherit; font-weight: 600; cursor: pointer; font-size: 0.8rem; }
    .btn-del:hover { background: #c0392b; color: #fff; }
    .btn-toggle { background: #f0f9f0; color: #2d6a1a; border: 1px solid #c3e6c3; padding: 0.4rem 0.8rem; border-radius: 6px; font-family: inherit; font-weight: 600; cursor: pointer; font-size: 0.8rem; }

    /* TABLES */
    .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .data-table th { background: #f8f8f8; padding: 0.75rem; text-align: left; font-weight: 700; color: #555; font-size: 0.75rem; text-transform: uppercase; }
    .data-table td { padding: 0.75rem; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: #fafff8; }
    .prod-thumb { width: 50px; height: 50px; border-radius: 8px; background-size: cover; background-position: center; background-color: #eee; }
    .badge { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.7rem; font-weight: 700; }
    .badge-green { background: #e8f5e9; color: #2d6a1a; }
    .badge-gold { background: #fff8e1; color: #b8860b; }
    .badge-gray { background: #f0f0f0; color: #888; }
    .badge-unread { background: #ffebee; color: #c0392b; }

    /* INQUIRY CARDS */
    .inq-card { border: 1px solid #f0f0f0; border-radius: 10px; padding: 1rem; margin-bottom: 1rem; }
    .inq-card.unread { border-color: #d4af37; background: #fffbf0; }
    .inq-meta { display: flex; gap: 1rem; flex-wrap: wrap; font-size: 0.8rem; color: #888; margin-bottom: 0.5rem; }
    .inq-meta strong { color: #222; }
    .inq-msg { font-size: 0.9rem; color: #444; margin-top: 0.5rem; line-height: 1.6; }
    .inq-actions { margin-top: 0.75rem; }

    /* COLLAPSIBLE FORM */
    .form-toggle-btn { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 700; color: #2d6a1a; background: #f0f9f0; border: 1px solid #c3e6c3; padding: 0.6rem 1rem; border-radius: 8px; cursor: pointer; }
    .add-form { display: none; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid #f0f0f0; }
    .add-form.open { display: block; }

    @media (max-width: 900px) {
      .admin-layout { flex-direction: column; }
      .sidebar { width: 100%; height: auto; position: relative; }
      .stats-row { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 600px) {
      .stats-row { grid-template-columns: 1fr; }
      .form-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div class="admin-layout">
  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sidebar-logo">
      <div class="icon">🌾</div>
      <div class="text"><h2>Al-Ahmed Agri</h2><p>Admin Panel</p></div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">Management</div>
      <a href="#products" onclick="scrollTo('products')">📦 Products</a>
      <a href="#gallery" onclick="scrollTo('gallery')">📷 Gallery</a>
      <a href="#inquiries" onclick="scrollTo('inquiries')">📬 Inquiries <% var unread = inquiries.filter(i=>!i.read).length; if(unread>0){%><span style="background:#c0392b;color:#fff;border-radius:20px;padding:0.1rem 0.5rem;font-size:0.7rem;margin-left:auto;"><%=unread%></span><%}%></a>
      <div class="nav-section">Website</div>
      <a href="/" target="_blank">🌐 View Website</a>
    </nav>
    <div class="sidebar-logout">
      <a href="/<%= slug %>/logout">🔒 Log Out</a>
    </div>
  </div>

  <!-- MAIN -->
  <div class="admin-main">
    <div class="admin-topbar">
      <div>
        <h1>Dashboard</h1>
        <p>Welcome back! Manage your products, gallery, and inquiries.</p>
      </div>
      <span class="badge-admin">🔐 Admin</span>
    </div>

    <!-- STATS -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="icon">📦</div>
        <div class="num"><%= products.length %></div>
        <div class="label">Total Products</div>
      </div>
      <div class="stat-card">
        <div class="icon">⭐</div>
        <div class="num"><%= products.filter(p=>p.featured).length %></div>
        <div class="label">Featured Products</div>
      </div>
      <div class="stat-card">
        <div class="icon">📷</div>
        <div class="num"><%= gallery.length %></div>
        <div class="label">Gallery Images</div>
      </div>
      <div class="stat-card">
        <div class="icon">📬</div>
        <div class="num"><%= inquiries.filter(i=>!i.read).length %></div>
        <div class="label">New Inquiries</div>
      </div>
    </div>

    <!-- PRODUCTS -->
    <div class="admin-section" id="products">
      <div class="section-head">
        <h2>📦 Products</h2>
        <button class="form-toggle-btn" onclick="toggleForm('addProductForm')">+ Add New Product</button>
      </div>

      <!-- ADD PRODUCT FORM -->
      <div class="add-form" id="addProductForm">
        <form method="POST" action="/<%= slug %>/products/add" enctype="multipart/form-data">
          <input type="hidden" name="uploadType" value="products">
          <div class="form-grid">
            <div class="form-group">
              <label>Product Name *</label>
              <input type="text" name="name" placeholder="e.g. Super Kernel Basmati Rice" required>
            </div>
            <div class="form-group">
              <label>Category *</label>
              <select name="category" required>
                <option value="basmati">Basmati Rice</option>
                <option value="non-basmati">Non-Basmati Rice</option>
              </select>
            </div>
            <div class="form-group full">
              <label>Description *</label>
              <textarea name="description" rows="3" placeholder="Describe the product..." required></textarea>
            </div>
            <div class="form-group">
              <label>Badge (optional)</label>
              <input type="text" name="badge" placeholder="e.g. Premium, Export Quality">
            </div>
            <div class="form-group">
              <label>Product Image</label>
              <input type="file" name="image" accept="image/*">
            </div>
            <div class="form-group">
              <label>Specification 1</label>
              <input type="text" name="spec1" placeholder="e.g. Grain Length: 7.2mm+">
            </div>
            <div class="form-group">
              <label>Specification 2</label>
              <input type="text" name="spec2" placeholder="e.g. Moisture: ≤12.5%">
            </div>
            <div class="form-group">
              <label>Specification 3</label>
              <input type="text" name="spec3" placeholder="e.g. Broken: ≤1%">
            </div>
            <div class="form-group">
              <label>Specification 4</label>
              <input type="text" name="spec4" placeholder="e.g. Purity: 99%+">
            </div>
            <div class="form-group">
              <label>Options</label>
              <div class="checkbox-row">
                <input type="checkbox" name="featured" id="featured">
                <label for="featured" style="text-transform:none; letter-spacing:0;">Show on Home Page (Featured)</label>
              </div>
            </div>
          </div>
          <div style="margin-top:1.25rem;">
            <button type="submit" class="btn-add">💾 Save Product</button>
            <button type="button" onclick="toggleForm('addProductForm')" style="margin-left:0.75rem; background:none; border:none; cursor:pointer; color:#888; font-size:0.875rem;">Cancel</button>
          </div>
        </form>
      </div>

      <!-- PRODUCTS TABLE -->
      <div style="overflow-x:auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Image</th>
              <th>Name</th>
              <th>Category</th>
              <th>Badge</th>
              <th>Featured</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(function(p) { %>
            <tr>
              <td><div class="prod-thumb" style="background-image:url('<%= p.image %>');"></div></td>
              <td><strong><%= p.name %></strong></td>
              <td><span class="badge badge-green"><%= p.category %></span></td>
              <td><%= p.badge || '—' %></td>
              <td><span class="badge <%= p.featured ? 'badge-gold' : 'badge-gray' %>"><%= p.featured ? '⭐ Yes' : 'No' %></span></td>
              <td style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                <form method="POST" action="/<%= slug %>/products/toggle-featured/<%= p.id %>" style="display:inline;">
                  <button type="submit" class="btn-toggle"><%= p.featured ? '★ Unfeature' : '☆ Feature' %></button>
                </form>
                <form method="POST" action="/<%= slug %>/products/delete/<%= p.id %>" onsubmit="return confirm('Delete this product?')" style="display:inline;">
                  <button type="submit" class="btn-del">🗑 Delete</button>
                </form>
              </td>
            </tr>
            <% }) %>
            <% if(products.length === 0) { %>
            <tr><td colspan="6" style="text-align:center; color:#888; padding:2rem;">No products yet. Add your first product above.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- GALLERY -->
    <div class="admin-section" id="gallery">
      <div class="section-head">
        <h2>📷 Gallery / Infrastructure</h2>
        <button class="form-toggle-btn" onclick="toggleForm('addGalleryForm')">+ Add Image</button>
      </div>

      <div class="add-form" id="addGalleryForm">
        <form method="POST" action="/<%= slug %>/gallery/add" enctype="multipart/form-data">
          <input type="hidden" name="uploadType" value="gallery">
          <div class="form-grid">
            <div class="form-group">
              <label>Title *</label>
              <input type="text" name="title" placeholder="e.g. Milling Plant" required>
            </div>
            <div class="form-group">
              <label>Caption</label>
              <input type="text" name="caption" placeholder="Short description">
            </div>
            <div class="form-group">
              <label>Category</label>
              <select name="category">
                <option value="facility">Facility</option>
                <option value="storage">Storage</option>
                <option value="farming">Farming</option>
                <option value="logistics">Logistics</option>
                <option value="quality">Quality</option>
              </select>
            </div>
            <div class="form-group">
              <label>Image *</label>
              <input type="file" name="image" accept="image/*" required>
            </div>
          </div>
          <div style="margin-top:1.25rem;">
            <button type="submit" class="btn-add">💾 Upload Image</button>
            <button type="button" onclick="toggleForm('addGalleryForm')" style="margin-left:0.75rem; background:none; border:none; cursor:pointer; color:#888; font-size:0.875rem;">Cancel</button>
          </div>
        </form>
      </div>

      <div style="overflow-x:auto; margin-top:1rem;">
        <table class="data-table">
          <thead>
            <tr><th>Image</th><th>Title</th><th>Caption</th><th>Category</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% gallery.forEach(function(g) { %>
            <tr>
              <td><div class="prod-thumb" style="background-image:url('<%= g.image %>');"></div></td>
              <td><strong><%= g.title %></strong></td>
              <td><%= g.caption || '—' %></td>
              <td><span class="badge badge-green"><%= g.category %></span></td>
              <td>
                <form method="POST" action="/<%= slug %>/gallery/delete/<%= g.id %>" onsubmit="return confirm('Delete this image?')" style="display:inline;">
                  <button type="submit" class="btn-del">🗑 Delete</button>
                </form>
              </td>
            </tr>
            <% }) %>
            <% if(gallery.length === 0) { %>
            <tr><td colspan="5" style="text-align:center; color:#888; padding:2rem;">No gallery images yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- INQUIRIES -->
    <div class="admin-section" id="inquiries">
      <div class="section-head">
        <h2>📬 Customer Inquiries</h2>
        <span class="badge <%= inquiries.filter(i=>!i.read).length > 0 ? 'badge-unread' : 'badge-gray' %>">
          <%= inquiries.filter(i=>!i.read).length %> unread
        </span>
      </div>
      <% if(inquiries.length === 0) { %>
        <p style="color:#888; text-align:center; padding:2rem;">No inquiries yet.</p>
      <% } else { %>
        <% inquiries.forEach(function(inq) { %>
        <div class="inq-card <%= !inq.read ? 'unread' : '' %>">
          <div class="inq-meta">
            <% if(!inq.read) { %><span class="badge badge-unread">● New</span><% } %>
            <strong><%= inq.name %></strong>
            <span>📧 <%= inq.email %></span>
            <% if(inq.phone) { %><span>📞 <%= inq.phone %></span><% } %>
            <span>🏷️ <%= inq.subject %></span>
            <span>🕐 <%= new Date(inq.date).toLocaleDateString('en-PK', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></span>
          </div>
          <div class="inq-msg"><%= inq.message %></div>
          <% if(!inq.read) { %>
          <div class="inq-actions">
            <form method="POST" action="/<%= slug %>/inquiries/read/<%= inq.id %>" style="display:inline;">
              <button type="submit" class="btn-toggle">✓ Mark as Read</button>
            </form>
          </div>
          <% } %>
        </div>
        <% }) %>
      <% } %>
    </div>

  </div><!-- end admin-main -->
</div><!-- end admin-layout -->

<script>
function toggleForm(id) {
  const f = document.getElementById(id);
  f.classList.toggle('open');
}
</script>
</body>
</html>
