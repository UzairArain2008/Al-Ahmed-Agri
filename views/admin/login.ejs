<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — Al-Ahmed Agri</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Nunito', sans-serif;
      background: linear-gradient(135deg, #0d1f0a 0%, #1a3a12 50%, #0d2a08 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .login-box {
      background: #fff;
      border-radius: 20px;
      padding: 3rem 2.5rem;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 30px 80px rgba(0,0,0,0.4);
    }
    .login-logo {
      text-align: center;
      margin-bottom: 2rem;
    }
    .login-logo .icon { font-size: 3rem; }
    .login-logo h1 { font-size: 1.4rem; font-weight: 700; color: #1a2a0a; margin-top: 0.5rem; }
    .login-logo p { color: #888; font-size: 0.85rem; margin-top: 0.25rem; }
    .admin-label {
      background: #d4af37;
      color: #fff;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      display: inline-block;
      margin-bottom: 1.5rem;
    }
    label { display: block; font-size: 0.85rem; font-weight: 600; color: #444; margin-bottom: 0.4rem; }
    input {
      width: 100%;
      padding: 0.8rem 1rem;
      border: 2px solid #e8e8e8;
      border-radius: 10px;
      font-family: inherit;
      font-size: 0.95rem;
      transition: border-color 0.2s;
      margin-bottom: 1.25rem;
    }
    input:focus { outline: none; border-color: #2d6a1a; }
    .btn-login {
      width: 100%;
      padding: 0.9rem;
      background: linear-gradient(135deg, #2d6a1a, #1a4010);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-family: inherit;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-login:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(45,106,26,0.4); }
    .error {
      background: #fff0f0;
      color: #c0392b;
      border: 1px solid #fcc;
      border-radius: 8px;
      padding: 0.75rem 1rem;
      margin-bottom: 1.25rem;
      font-size: 0.875rem;
    }
    .back-link {
      display: block;
      text-align: center;
      margin-top: 1.5rem;
      color: #888;
      text-decoration: none;
      font-size: 0.875rem;
    }
    .back-link:hover { color: #2d6a1a; }
  </style>
</head>
<body>
  <div class="login-box">
    <div class="login-logo">
      <div class="icon">🌾</div>
      <h1>Al-Ahmed Agri</h1>
      <p>Management Portal</p>
    </div>
    <div style="text-align:center; margin-bottom:1.5rem;">
      <span class="admin-label">🔐 Admin Access</span>
    </div>
    <% if (error) { %>
    <div class="error"><%= error %></div>
    <% } %>
    <form method="POST" action="/<%= slug %>/login">
      <label for="username">Username</label>
      <input type="text" id="username" name="username" placeholder="Enter username" required autofocus>
      <label for="password">Password</label>
      <input type="password" id="password" name="password" placeholder="Enter password" required>
      <button type="submit" class="btn-login">Sign In to Admin Panel</button>
    </form>
    <a href="/" class="back-link">← Back to Website</a>
  </div>
</body>
</html>
