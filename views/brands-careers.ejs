<%- include('partials/header', { title: 'Brands & Careers' }) %>

<!-- PAGE HERO - Brands -->
<section class="brands-hero">
  <div class="brands-hero-bg"></div>
  <div class="brands-hero-content">
    <div class="section-label" style="color:#d4af37; margin-bottom:1rem;">Our Identity</div>
    <h1>Brands & <span class="gold">Careers</span></h1>
    <p>Trusted brands built over decades. A team built on passion and purpose.</p>
  </div>
</section>

<!-- BRANDS SECTION -->
<section class="section" id="brands">
  <div class="container">
    <div class="section-header">
      <div class="section-label">Our Brands</div>
      <h2>Names the Market <span class="gold">Trusts</span></h2>
      <p>Our brand portfolio covers premium to everyday segments, giving us a presence across all market tiers.</p>
    </div>

    <div class="brands-grid">
      <div class="brand-card brand-primary">
        <div class="brand-emblem">🌾</div>
        <div class="brand-name">Al-Ahmed Gold</div>
        <div class="brand-tagline">The Pinnacle of Purity</div>
        <p>Our flagship premium line — featuring top-grade Super Kernel and 1121 Basmati rice. Reserved for the most discerning buyers and premium retail markets.</p>
        <div class="brand-tags">
          <span>Super Kernel</span>
          <span>1121 Basmati</span>
          <span>Export Premium</span>
        </div>
      </div>

      <div class="brand-card brand-secondary">
        <div class="brand-emblem">🌿</div>
        <div class="brand-name">Sindh Fields</div>
        <div class="brand-tagline">From the Heartland, To Your Table</div>
        <p>Our mid-range consumer brand, bringing the authentic flavors of Sindh's fertile fields to households across Pakistan and the Middle East.</p>
        <div class="brand-tags">
          <span>PK-386 Basmati</span>
          <span>IRRI-6</span>
          <span>Retail Packs</span>
        </div>
      </div>

      <div class="brand-card brand-tertiary">
        <div class="brand-emblem">⭐</div>
        <div class="brand-name">AgriValue</div>
        <div class="brand-tagline">Quality Without Compromise. Price Without Guilt.</div>
        <p>An economical bulk brand designed for food service, institutions, and industry. Reliable quality at competitive pricing for high-volume buyers.</p>
        <div class="brand-tags">
          <span>IRRI-9</span>
          <span>Broken Rice</span>
          <span>Bulk 50kg</span>
        </div>
      </div>
    </div>

    <div class="brand-note">
      <div class="bn-icon">🏷️</div>
      <div>
        <strong>Private Label Available</strong>
        <p>We manufacture under private label for international distributors and retail chains. Contact us to discuss custom branding options for your market.</p>
      </div>
      <a href="#contact-section" class="btn-outline">Inquire Now</a>
    </div>
  </div>
</section>

<!-- CAREERS SECTION -->
<section class="section section-alt" id="careers">
  <div class="container">
    <div class="section-header">
      <div class="section-label">Opportunities</div>
      <h2>Join <span class="gold">Al Ahmed (Pvt.) Ltd.</span></h2>
      <p>Al Ahmed (Pvt.) Ltd. welcomes new recruits, we're always looking for professional and talented individuals who thrive on team work and innovation. We strive to achieve employee satisfaction and career growth options. If you wish to be a part of the Al Ahmed family, please submit your resume at the below given E-mail Address.</p>
      <div style="margin-top: 1.5rem;">
        <a href="mailto:info@alahmedagri.com" class="btn-primary" style="text-transform: lowercase;">info@alahmedagri.com</a>
      </div>
    </div>

  </div>
</section>

<!-- CULTURE SECTION -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <div class="section-label">Our Culture</div>
      <h2>Why Work With <span class="gold">Us</span></h2>
    </div>
    <div class="culture-grid">
      <div class="culture-item">
        <div class="culture-icon">📈</div>
        <h4>Growth Opportunities</h4>
        <p>We invest in our people. From on-the-job training to leadership development, we help you grow alongside the company.</p>
      </div>
      <div class="culture-item">
        <div class="culture-icon">🤝</div>
        <h4>Collaborative Team</h4>
        <p>A family-owned business culture where every voice matters and contributions are recognized and rewarded.</p>
      </div>
      <div class="culture-item">
        <div class="culture-icon">🌍</div>
        <h4>Global Exposure</h4>
        <p>Work with international buyers, exporters, and partners from across Asia, the Middle East, Africa, and Europe.</p>
      </div>
      <div class="culture-item">
        <div class="culture-icon">🏡</div>
        <h4>Work-Life Balance</h4>
        <p>Reasonable hours, fair compensation, and a supportive work environment that respects your personal life.</p>
      </div>
    </div>
  </div>
</section>

