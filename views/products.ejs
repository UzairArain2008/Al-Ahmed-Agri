<%- include('partials/header', { title: 'Products' }) %>

<!-- PAGE HERO -->
<section class="page-hero" style="background-image: linear-gradient(135deg, #1a2a0a 0%, #2d4a12 100%);">
  <div class="page-hero-content">
    <div class="section-label" style="color:#d4af37; margin-bottom:1rem;">Our Range</div>
    <h1>Premium <span class="gold">Rice Products</span></h1>
    <p>Basmati and Non-Basmati varieties — sourced, milled, and graded to the highest export standards.</p>
  </div>
</section>

<!-- CATEGORY FILTER -->
<div class="category-bar">
  <div class="container">
    <div class="cat-filters">
      <a href="/products?cat=all" class="cat-btn <%= activeCategory==='all' ? 'active' : '' %>">All Products</a>
      <% uniqueCategories.forEach(function(cat) { 
        if (!cat) return;
        const catName = typeof cat === 'string' ? cat.replace(/-/g, ' ') : String(cat);
      %>
      <a href="/products?cat=<%= encodeURIComponent(cat) %>" class="cat-btn <%= activeCategory===cat ? 'active' : '' %>" style="text-transform: capitalize;">🌾 <%= catName %></a>
      <% }); %>
    </div>
  </div>
</div>

<!-- PRODUCTS SECTION -->
<section class="section">
  <div class="container">
    <% if (products.length === 0) { %>
    <div class="empty-state">
      <div style="font-size:4rem;">🌾</div>
      <h3>No products in this category yet</h3>
      <p>Check back soon or contact us for a full product list.</p>
    </div>
    <% } else { %>
    <div class="products-full-grid">
      <% products.forEach(function(p) { 
        const catDisp = (p.category && typeof p.category === 'string') ? p.category.replace(/-/g, ' ') : (p.category || 'Uncategorized');
      %>
      <div class="product-full-card">
        <div class="pfc-img-col">
          <div class="pfc-img" style="background-image:url('<%= p.image %>');"></div>
          <% if(p.badge) { %><div class="product-badge"><%= p.badge %></div><% } %>
        </div>
        <div class="pfc-body">
          <div class="pfc-cat-tag" style="text-transform: capitalize;">🌾 <%= catDisp %></div>
          <h2><%= p.name %></h2>
          <p class="pfc-desc"><%= p.description %></p>
          <% if(p.specs && p.specs.length > 0) { %>
          <div class="pfc-specs">
            <h4>Specifications</h4>
            <div class="specs-grid">
              <% p.specs.forEach(function(s) { %>
              <div class="spec-chip">✓ <%= s %></div>
              <% }) %>
            </div>
          </div>
          <% } %>
          <div class="pfc-actions">
            <a href="#contact-section" class="btn-primary">Request Quote</a>
            <a href="#contact-section" class="btn-outline">Get Sample</a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</section>

<!-- NOTE SECTION -->
<section class="section section-alt">
  <div class="container">
    <div class="note-banner">
      <div class="nb-icon">📦</div>
      <div class="nb-text">
        <h3>Custom Packaging & Private Label Available</h3>
        <p>We offer flexible packaging from 1kg retail packs to 50kg bulk sacks. Private labeling and custom branding available for wholesale buyers. Contact us for details.</p>
      </div>
      <a href="#contact-section" class="btn-primary">Contact Us</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
