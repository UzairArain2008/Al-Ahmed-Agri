<%- include('partials/header', { title: 'About Us' }) %>

<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <div class="section-label" style="color:#d4af37; margin-bottom:1rem;">Our Story</div>
    <h1>About <span class="gold">Al Ahmed Rice Agro Exports</span></h1>
    <p>A legacy of quality, honesty, and agricultural excellence — rooted in Pakistan, trusted worldwide.</p>
  </div>
</section>

<!-- STORY SECTION -->
<section class="section">
  <div class="container">
    <div class="story-grid">
      <div class="story-text">
        <div class="section-label">Est. 1998</div>
        <h2>A Quarter Century of <span class="gold">Rice Excellence</span></h2>
        <p>Al Ahmed Rice Agro Exports was founded in 1998 in Sukkur, Sindh, by a family with deep roots in Pakistan's agricultural heartland. Starting as a small rice trading operation, we have grown into one of the region's most respected rice processing and export companies.</p>
        <p style="margin-top:1rem;">Over 25 years, we have built lasting relationships with farmers across Punjab and Sindh, invested in modern milling and processing technology, and developed a customer base spanning 40+ countries across the Middle East, Asia, Africa, and Europe.</p>
        <p style="margin-top:1rem;">Our philosophy is simple: never compromise on quality. Every grain that leaves our facility has been carefully processed, tested, and graded to meet the highest standards our customers deserve.</p>
        <div class="about-highlights">
          <div class="ah-item"><strong>1998</strong><span>Founded in Sukkur</span></div>
          <div class="ah-item"><strong>40+</strong><span>Countries Served</span></div>
          <div class="ah-item"><strong>50,000 MT</strong><span>Annual Capacity</span></div>
        </div>
      </div>
      <div class="story-visual">
        <div class="story-img-main"></div>
        <div class="story-badge-float">
          <div class="sbf-num">25+</div>
          <div class="sbf-text">Years of Trust</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHY CHOOSE US -->
<section class="section section-alt" id="why-us">
  <div class="container">
    <div class="section-header">
      <div class="section-label">Why Choose Us</div>
      <h2>What Sets Us <span class="gold">Apart</span></h2>
      <p>We combine decades of expertise with modern infrastructure to deliver an experience our clients trust and return to.</p>
    </div>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-num">01</div>
        <div class="why-icon">🏭</div>
        <h3>Modern Milling Facility</h3>
        <p>Our 50,000 MT capacity plant uses the latest Japanese and German machinery for precise milling, sorting, and packaging — minimizing breakage and maximizing grain quality.</p>
      </div>
      <div class="why-card">
        <div class="why-num">02</div>
        <div class="why-icon">🔬</div>
        <h3>ISO-Standard Quality Control</h3>
        <p>Our in-house laboratory performs rigorous tests on every lot: moisture content, purity grade, grain length, chalk percentage, and aroma profile — before and after processing.</p>
      </div>
      <div class="why-card">
        <div class="why-num">03</div>
        <div class="why-icon">🚜</div>
        <h3>Direct Farm Procurement</h3>
        <p>We work directly with contracted farmers across Punjab and Sindh, cutting out middlemen and ensuring traceability, freshness, and fair pricing throughout the supply chain.</p>
      </div>
      <div class="why-card">
        <div class="why-num">04</div>
        <div class="why-icon">📦</div>
        <h3>Flexible Packaging</h3>
        <p>From 1kg retail bags to 50kg bulk sacks — we offer customized packaging with private label options for international distributors and retailers.</p>
      </div>
      <div class="why-card">
        <div class="why-num">05</div>
        <div class="why-icon">🌍</div>
        <h3>Export Expertise</h3>
        <p>25+ years of export experience means we handle all documentation — phytosanitary certificates, fumigation, inspection, and freight — with full regulatory compliance.</p>
      </div>
      <div class="why-card">
        <div class="why-num">06</div>
        <div class="why-icon">🤝</div>
        <h3>Long-Term Partnerships</h3>
        <p>We don't just sell rice — we build relationships. Our repeat customer rate exceeds 85%, built on consistent delivery, fair pricing, and transparent communication.</p>
      </div>
    </div>
  </div>
</section>

<!-- GALLERY PREVIEW -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <div class="section-label">Our Infrastructure</div>
      <h2>A Glimpse of Our <span class="gold">Facility</span></h2>
    </div>
    <div class="about-gallery-grid">
      <% gallery.forEach(function(g, i) { %>
      <div class="about-gal-item">
        <div class="gal-img" style="background-image:url('<%= g.image %>');"></div>
        <div class="gal-overlay"><span><%= g.title %></span></div>
      </div>
      <% }) %>
    </div>
    <div style="text-align:center; margin-top:2.5rem;">
      <a href="/gallery" class="btn-primary">See Full Infrastructure Gallery</a>
    </div>
  </div>
</section>

<!-- COMPANY INTRO & REGISTRATIONS -->
<section class="section">
  <div class="container">
    <div class="intro-registration-wrap">

      <!-- Company Introduction -->
      <div class="company-intro-block">
        <div class="section-label">Who We Are</div>
        <h2>Al Ahmed Rice Agro Exports — <span class="gold">Our Story</span></h2>
        <p class="intro-lead">Established in 1998, Al Ahmed Rice Agro Exports has built a strong reputation in the domestic rice market through consistent quality, reliability, and trust.</p>
        <p class="intro-body">With decades of experience in rice processing and trade, we are now expanding into international markets to deliver premium Basmati and Non-Basmati rice. We are committed to excellence, timely delivery, and competitive pricing — values that have defined us for over 25 years.</p>
        <p class="intro-body">Our goal is to become a trusted global supplier by building long-term partnerships with clients around the world, backed by internationally recognized registrations and a deep understanding of agricultural trade.</p>
        <a href="/about" class="btn-primary" style="margin-top: 1.5rem; display: inline-block;">Learn More About Us</a>
      </div>

      <!-- Registered With Logos -->
      <div class="reg-logos-block">
        <div class="section-label">Registered & Recognized By</div>
        <div class="reg-logos-grid">
          <div class="reg-logo-item">
            <img src="/images/logo-psw.jpeg" alt="Pakistan Single Window (PSW)" loading="lazy">
            <span>PSW</span>
          </div>
          <div class="reg-logo-item">
            <img src="/images/logo-ipo.jpeg" alt="Intellectual Property Organisation (IPO)" loading="lazy">
            <span>IPO Pakistan</span>
          </div>
          <div class="reg-logo-item">
            <img src="/images/logo-secp.jpeg" alt="Securities & Exchange Commission of Pakistan (SECP)" loading="lazy">
            <span>SECP</span>
          </div>
          <div class="reg-logo-item">
            <img src="/images/logo-tdap.jpeg" alt="Trade Development Authority of Pakistan (TDAP)" loading="lazy">
            <span>TDAP</span>
          </div>
          <div class="reg-logo-item">
            <img src="/images/logo-fbr.jpeg" alt="Federal Board of Revenue (FBR)" loading="lazy">
            <span>FBR Pakistan</span>
          </div>
          <div class="reg-logo-item">
            <img src="/images/logo-kcci.jpeg" alt="Karachi Chamber of Commerce & Industry (KCCI)" loading="lazy">
            <span>KCCI</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- TEAM / VALUES -->
<section class="section section-alt">
  <div class="container">
    <div class="section-header">
      <div class="section-label">Our Values</div>
      <h2>The Principles We <span class="gold">Live By</span></h2>
    </div>
    <div class="values-row">
      <div class="value-item">
        <div class="value-circle">🌾</div>
        <h4>Quality First</h4>
        <p>No batch ships unless it meets our strict specification sheet. Period.</p>
      </div>
      <div class="value-item">
        <div class="value-circle">⚖️</div>
        <h4>Fair Trade</h4>
        <p>We pay fair prices to our farmers and offer fair deals to our buyers.</p>
      </div>
      <div class="value-item">
        <div class="value-circle">🕊️</div>
        <h4>Integrity</h4>
        <p>What we promise, we deliver — in quality, quantity, and timeline.</p>
      </div>
      <div class="value-item">
        <div class="value-circle">♻️</div>
        <h4>Sustainability</h4>
        <p>Responsible farming practices and waste reduction in all operations.</p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
